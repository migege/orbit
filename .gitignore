# No trailing slash: also ignore a symlink named node_modules (a worktree may
# symlink it to the main checkout). With a slash, git tracks such symlinks and a
# later checkout clobbers the real deps with a self-referential link.
node_modules
dist/
dist-bin/
build/
coverage/
tmp/
*.log
*.tsbuildinfo

# env
.env
.env.local
.env.*.local

# runner local state
.orbit/

# claude worktrees
.claude/worktrees/

# prisma local db
*.db

# postgres bind-mount data
/data/

# os
.DS_Store
Thumbs.db

# go build artifact (a bare `go build` in src/runner-go; real builds -> dist-bin/)
/src/runner-go/orbit

# swift / swiftpm build output (macOS client under src/macos/*) — generated, not source
.build/
.swiftpm/
DerivedData/
