# ──────────────────────────── Control plane (orbit server) ────────────────────────────
DATABASE_URL="postgresql://orbit:orbit@localhost:5432/orbit?schema=public"
# Required — no default. Generate a strong secret: openssl rand -base64 32
JWT_SECRET=""
PORT=3000
# Public origin users reach this deployment at — shown in the "Add a runner" install
# commands. Baked into the web bundle at build time, so changing it needs a web rebuild
# (the deploy/upgrade already rebuilds). Defaults to the local gateway for self-hosting;
# set it to your public URL (e.g. https://orbit.example.com) when serving behind a domain.
PUBLIC_ORIGIN="http://localhost:2086"

# ──────────────────────────── Runner (set on the user's machine) ───────────────────────
# Written by `orbit register` into ~/.orbit/config.json; shown here for reference only.
# ORBIT_SERVER_URL="http://localhost:3000"
# ORBIT_RUNNER_TOKEN="<long-lived runner credential issued by `orbit register`>"

# Claude Code auth on the runner machine (never sent to the control plane).
# OPTIONAL: if none of these are set, the runner uses `claude -p` with the machine's
# interactive login (run `claude` once and `/login`). Set one for non-interactive auth
# instead:
# ANTHROPIC_API_KEY="<your-anthropic-api-key>"            # usage-based billing
# CLAUDE_CODE_OAUTH_TOKEN="<from `claude setup-token`>"   # subscription billing, non-interactive
