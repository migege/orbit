// Orbit control-plane data model. See src/shared/src/enums.ts for the
// TypeScript mirrors of these enums (kept in sync by string value).
//
// DB-level table/column/enum names are mapped to snake_case via @@map/@map to
// follow PostgreSQL conventions. Prisma Client field names stay camelCase, so
// application code is unaffected; only raw SQL references the mapped names.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
  // Interactive sessions (Route B). Appended last to match ALTER TYPE ADD VALUE.
  AWAITING_INPUT
  INTERRUPTED

  @@map("run_status")
}

enum RunnerStatus {
  ONLINE
  OFFLINE
  DRAINING

  @@map("runner_status")
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED

  @@map("task_status")
}

// Who/what authored a Task. The creator is a polymorphic reference (no FK),
// so a Task can be created by a user or by an agent (agent-spawned subtasks).
enum CreatorType {
  USER
  AGENT

  @@map("creator_type")
}

model User {
  id           String   @id @default(uuid(7)) @db.Uuid
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  agents           Agent[]
  runners          Runner[]
  enrollmentTokens EnrollmentToken[]
  ownedSessions    Session[]         @relation("SessionOwner")
  createdSessions  Session[]         @relation("SessionCreator")
  ownedTasks       Task[] // tasks this user owns (tenant scope)
  taskLists        TaskList[] // task lists this user owns (tenant scope)

  @@map("user")
}

// A machine the user registered via `orbit register`. Claude Code runs here.
model Runner {
  id              String       @id @default(uuid(7)) @db.Uuid
  name            String
  // User-set friendly name shown in the UI. `name` stays the machine-reported
  // identity used to match re-registrations, so renaming never creates a dup.
  displayName     String?      @map("display_name")
  hostname        String?
  ownerId         String       @map("owner_id") @db.Uuid
  owner           User         @relation(fields: [ownerId], references: [id])
  labels          String[]     @default([])
  status          RunnerStatus @default(OFFLINE)
  maxConcurrent   Int          @default(1) @map("max_concurrent")
  version         String?
  tokenHash       String       @map("token_hash") // hash of the long-lived runner credential
  lastHeartbeatAt DateTime?    @map("last_heartbeat_at")
  enrolledAt      DateTime     @default(now()) @map("enrolled_at")

  sessions Session[]
  // Agents `orbit register` minted for this machine (one per project dir + tool).
  agents   Agent[]

  @@index([ownerId])
  @@map("runner")
}

// One-time token a user generates in the UI and passes to `orbit register`.
model EnrollmentToken {
  id        String    @id @default(uuid(7)) @db.Uuid
  tokenHash String    @unique @map("token_hash")
  ownerId   String    @map("owner_id") @db.Uuid
  owner     User      @relation(fields: [ownerId], references: [id])
  label     String?
  expiresAt DateTime? @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("enrollment_token")
}

// A pending `orbit register` device-login session (RFC 8628-style browser flow).
// The CLI polls with the secret deviceCode; a logged-in user approves the machine
// in the browser by the short, human-typable userCode.
model DeviceEnrollment {
  id             String    @id @default(uuid(7)) @db.Uuid
  deviceCodeHash String    @unique @map("device_code_hash") // hash of the secret the CLI polls with
  userCode       String    @unique @map("user_code") // short code shown in the browser + terminal
  name           String
  hostname       String?
  labels         String[]  @default([])
  maxConcurrent  Int       @default(1) @map("max_concurrent")
  version        String?
  status         String    @default("PENDING") // PENDING | APPROVED
  // Agent (coding-tool) keys requested at device/start; approval mints one Runner
  // for the machine (named by hostname) and one Agent per key (named `<name>/<key>`).
  agents         String[]  @default([])
  // The project directory the minted agents run in (claude's cwd), from the CLI.
  workDir        String?   @map("work_dir")
  runnerId       String?   @map("runner_id") @db.Uuid // the machine runner minted on approval
  runnerToken    String?   @map("runner_token") // raw runner credential, delivered to the CLI once then cleared
  // The minted agents [{agentKey,agentId,name,workDir}], delivered to the CLI once
  // on poll then wiped (mirrors runnerToken above). Column kept named `runners`.
  mintedAgents   Json?     @map("runners")
  approvedById   String?   @map("approved_by_id") @db.Uuid
  approvedAt     DateTime? @map("approved_at")
  expiresAt      DateTime  @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@map("device_enrollment")
}

// An agent definition: how to drive Claude Code for a class of sessions.
model Agent {
  id                 String   @id @default(uuid(7)) @db.Uuid
  name               String
  description        String?
  model              String   @default("claude-sonnet-4-6")
  appendSystemPrompt String?  @map("append_system_prompt")
  systemPrompt       String?  @map("system_prompt")
  allowedTools       Json     @default("[]") @map("allowed_tools")
  disallowedTools    Json     @default("[]") @map("disallowed_tools")
  permissionMode     String   @default("dontAsk") @map("permission_mode")
  maxTurns           Int?     @map("max_turns")
  maxBudgetUsd       Float?   @map("max_budget_usd")
  mcpConfig          Json?    @map("mcp_config")
  // routing: bind to a specific runner and/or match runner labels
  targetRunnerId     String?  @map("target_runner_id") @db.Uuid
  targetLabels       String[] @default([]) @map("target_labels")
  // The machine (Runner) this agent belongs to, set when `orbit register` mints it;
  // null for hand-made config agents. Cascade so unregistering a machine drops them.
  runnerId           String?  @map("runner_id") @db.Uuid
  runner             Runner?  @relation(fields: [runnerId], references: [id], onDelete: Cascade)
  // The project directory claude runs in for this agent, and its coding-tool key.
  workDir            String?  @map("work_dir")
  agentKey           String?  @map("agent_key")
  enabled            Boolean  @default(true)
  ownerId            String   @map("owner_id") @db.Uuid
  owner              User     @relation(fields: [ownerId], references: [id])
  createdAt          DateTime @default(now()) @map("created_at")

  sessions      Session[]
  assignedTasks Task[] // tasks assigned to this agent to execute

  @@index([ownerId])
  @@index([runnerId])
  @@map("agent")
}

// A first-class interactive chat session (Route B): a long-lived conversation
// driven by one claude process on a runner. Chat events, user-input turns, tool
// calls, and llm usage hang directly off the Session.
model Session {
  id                String    @id @default(uuid(7)) @db.Uuid
  title             String
  prompt            String // first-turn seed
  ownerId           String    @map("owner_id") @db.Uuid
  owner             User      @relation("SessionOwner", fields: [ownerId], references: [id])
  creatorId         String    @map("creator_id") @db.Uuid
  creator           User      @relation("SessionCreator", fields: [creatorId], references: [id])
  assignedRunnerId  String?   @map("assigned_runner_id") @db.Uuid
  assignedRunner    Runner?   @relation(fields: [assignedRunnerId], references: [id])
  agentId           String?   @map("agent_id") @db.Uuid
  agent             Agent?    @relation(fields: [agentId], references: [id])
  // Optional parent work item; deleting the Task detaches but keeps the session.
  taskId            String?   @map("task_id") @db.Uuid
  task              Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  // Pre-generated Claude session id: --session-id on first spawn, --resume on
  // reclaim/respawn.
  claudeSessionId   String?   @map("claude_session_id")
  model             String? // per-session override; null -> agent -> server default
  permissionMode    String?   @map("permission_mode")
  // Claude effort level (low|medium|high|xhigh|max); null omits --effort so claude
  // uses the model's default.
  effort            String?
  // PENDING = created, claimable by its assigned runner.
  status            RunStatus @default(PENDING)
  // billing, accrued per turn
  sumInputTokens    Int       @default(0) @map("sum_input_tokens")
  sumOutputTokens   Int       @default(0) @map("sum_output_tokens")
  sumCacheRead      Int       @default(0) @map("sum_cache_read")
  sumCacheWrite     Int       @default(0) @map("sum_cache_write")
  numTurns          Int       @default(0) @map("num_turns")
  costUsd           Float     @default(0) @map("cost_usd")
  lastTurnAt        DateTime? @map("last_turn_at")
  cancelRequestedAt DateTime? @map("cancel_requested_at")
  startedAt         DateTime? @map("started_at")
  finishedAt        DateTime? @map("finished_at")
  error             String?
  result            String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  events    RunEvent[]
  turns     ConversationTurn[]
  toolCalls ToolCall[]
  llmUsage  LlmUsage[]
  approvals Approval[]

  @@index([assignedRunnerId, status])
  @@index([ownerId])
  @@index([status])
  @@map("session")
}

// A tool-permission request from claude's --permission-prompt-tool (served by the
// runner's orbit MCP server), awaiting a human allow/deny. The MCP tool blocks on a
// long-poll until status flips. Not a RunEvent: the orbit MCP server is a separate
// process from the runner's seq-owning session loop, so persisting it as an event
// would race the runner's monotonic seq. Idempotent on (sessionId, toolUseId).
model Approval {
  id          String    @id @default(uuid(7)) @db.Uuid
  sessionId   String    @map("session_id") @db.Uuid
  session     Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  toolName    String    @map("tool_name")
  input       Json
  toolUseId   String?   @map("tool_use_id")
  // PENDING -> ALLOWED | DENIED
  status      String    @default("PENDING")
  message     String? // optional deny reason / note from the human
  // User who decided it (no FK; cf. Activity.actorId).
  decidedById String?   @map("decided_by_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  decidedAt   DateTime? @map("decided_at")

  @@unique([sessionId, toolUseId])
  @@index([sessionId, status])
  @@map("approval")
}

// Normalized streamed events for a session (replay + live SSE).
model RunEvent {
  id        String   @id @default(uuid(7)) @db.Uuid
  sessionId String   @map("session_id") @db.Uuid
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  seq       Int
  type      String
  payload   Json
  // conversation_turn.id that produced this event; null for session-level events.
  // No FK: high-volume append-only log (cf. Activity); both cascade-delete via session.
  turnId    String?  @map("turn_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([sessionId, seq])
  @@index([sessionId, seq])
  @@index([turnId])
  @@map("run_event")
}

// Audit of every tool the agent invoked during a session.
model ToolCall {
  id         String    @id @default(uuid(7)) @db.Uuid
  sessionId  String    @map("session_id") @db.Uuid
  session    Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name       String
  input      Json?
  output     Json?
  isError    Boolean   @default(false) @map("is_error")
  startedAt  DateTime? @map("started_at")
  finishedAt DateTime? @map("finished_at")

  @@index([sessionId])
  @@map("tool_call")
}

// Per-model token/cost detail for billing rollups.
model LlmUsage {
  id                       String   @id @default(uuid(7)) @db.Uuid
  sessionId                String   @map("session_id") @db.Uuid
  session                  Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  model                    String
  inputTokens              Int      @default(0) @map("input_tokens")
  outputTokens             Int      @default(0) @map("output_tokens")
  cacheCreationInputTokens Int      @default(0) @map("cache_creation_input_tokens")
  cacheReadInputTokens     Int      @default(0) @map("cache_read_input_tokens")
  costUsd                  Float    @default(0) @map("cost_usd")
  createdAt                DateTime @default(now()) @map("created_at")

  @@index([sessionId])
  @@map("usage")
}

// Durable, server-owned queue of user inputs for an interactive session (Route B).
// The runner long-polls these via GET /runner/sessions/:id/inbox; delivery is
// at-least-once with a lease + idempotency on (sessionId, clientTurnId).
model ConversationTurn {
  id              String    @id @default(uuid(7)) @db.Uuid
  sessionId       String    @map("session_id") @db.Uuid
  session         Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  seq             Int // server-assigned, per-session delivery ordering
  clientTurnId    String    @map("client_turn_id") // client-supplied idempotency key
  kind            String    @default("message") // message | interrupt | end
  content         String? // user message text (null for interrupt/end)
  status          String    @default("PENDING") // PENDING | IN_FLIGHT | ANSWERED
  deliveredAt     DateTime? @map("delivered_at")
  leaseDeadlineAt DateTime? @map("lease_deadline_at")
  answeredAt      DateTime? @map("answered_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@unique([sessionId, clientTurnId])
  @@unique([sessionId, seq])
  @@index([sessionId, status])
  @@map("conversation_turn")
}

// Lightweight activity feed (no FKs, append-only).
model Activity {
  id        String   @id @default(uuid(7)) @db.Uuid
  actorId   String?  @map("actor_id") @db.Uuid
  type      String
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("activity")
}

// A user-created grouping of Tasks. Minimal: just a title + tenant scope.
// Deleting a list detaches its tasks (Task.listId -> null), never deletes them.
model TaskList {
  id        String   @id @default(uuid(7)) @db.Uuid
  title     String
  // Tenant scope: list/authorization always filter by this column (like tasks).
  ownerId   String   @map("owner_id") @db.Uuid
  owner     User     @relation(fields: [ownerId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tasks Task[]

  @@index([ownerId])
  @@map("task_list")
}

// A human-facing work item (unrelated to the old execution-Task dropped in 0006).
// Created by a user or an agent, optionally assigned to an agent to execute; the
// agent's runs hang off it as Sessions.
model Task {
  id          String      @id @default(uuid(7)) @db.Uuid
  title       String
  description String?
  status      TaskStatus  @default(OPEN)
  // Tenant scope: list/authorization always filter by this column (like agents/sessions).
  ownerId     String      @map("owner_id") @db.Uuid
  owner       User        @relation(fields: [ownerId], references: [id])
  // Polymorphic creator (no FK, cf. Activity.actorId): who/what authored the task.
  creatorType CreatorType @map("creator_type")
  creatorId   String      @map("creator_id") @db.Uuid
  // The agent assigned to execute it (real FK, optional).
  assigneeId  String?     @map("assignee_id") @db.Uuid
  assignee    Agent?      @relation(fields: [assigneeId], references: [id])
  // Optional parent list grouping; deleting the list detaches but keeps the task.
  listId      String?     @map("list_id") @db.Uuid
  list        TaskList?   @relation(fields: [listId], references: [id], onDelete: SetNull)
  dueDate     DateTime?   @map("due_date")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  comments TaskComment[]
  sessions Session[] // agent sessions run under this task (one Task -> many Session)

  @@index([ownerId])
  @@index([assigneeId])
  @@index([listId])
  @@index([status])
  @@index([creatorType, creatorId])
  @@map("task")
}

// Comments on a Task (dedicated table; append-only MVP: create/list/delete).
model TaskComment {
  id         String      @id @default(uuid(7)) @db.Uuid
  taskId     String      @map("task_id") @db.Uuid
  task       Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  // Polymorphic author (no FK, cf. Task.creatorId): a comment can be written by a
  // user (web) or by an agent (via the runner MCP path). Names are resolved in code.
  authorType CreatorType @map("author_type")
  authorId   String      @map("author_id") @db.Uuid
  body       String
  createdAt  DateTime    @default(now()) @map("created_at")

  @@index([taskId, createdAt])
  @@map("task_comment")
}
