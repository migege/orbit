<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  APNs: `production` is what App Store / TestFlight distribution builds use (they receive on the
	  production APNs host). Local Xcode debug builds would need `development` + the sandbox host; that
	  variant is deferred (add an Orbit.Debug.entitlements + a per-config CODE_SIGN_ENTITLEMENTS when
	  we want on-device debug pushes). The client reports its environment to the server on register,
	  so the server picks the matching APNs host per token.
	-->
	<key>aps-environment</key>
	<string>production</string>
</dict>
</plist>
